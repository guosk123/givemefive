page {
  min-height: 100%;
  background: #f7f8fa;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 32rpx;
}

.panel {
  border-radius: 16rpx;
  padding: 32rpx;
  background: #ffffff;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.muted {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}
