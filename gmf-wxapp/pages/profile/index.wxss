.profile-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  min-width: 0;
}

.profile-copy {
  min-width: 0;
  margin-left: 24rpx;
}

.profile-copy .muted {
  word-break: break-all;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  flex: 0 0 112rpx;
  border-radius: 56rpx;
  background: #e5eefc;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1677ff;
  font-size: 44rpx;
  font-weight: 700;
}

.refresh-button {
  width: 144rpx;
  flex: 0 0 144rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 28rpx;
}

.error-panel {
  margin-top: 24rpx;
  border-radius: 8rpx;
  padding: 24rpx;
  background: #fff1f0;
  color: #cf1322;
  font-size: 26rpx;
}

.detail-panel {
  margin-top: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f5;
}

.detail-row:last-child {
  border-bottom: 0;
}

.detail-label {
  flex: 0 0 150rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.detail-value {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 28rpx;
  text-align: right;
  word-break: break-all;
}
