.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.summary-item {
  border-radius: 8rpx;
  padding: 24rpx 18rpx;
  background: #ffffff;
  border-left: 6rpx solid #1677ff;
}

.summary-label {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
}

.summary-value {
  display: block;
  margin-top: 12rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  word-break: break-all;
}

.total-panel {
  margin-top: 24rpx;
}

.total-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
}

.total-label {
  color: #6b7280;
  font-size: 28rpx;
}

.total-value {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.form-panel {
  margin-top: 24rpx;
}

.form-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.section-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.cancel-button {
  width: 112rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf0f5;
}

.remark-row {
  border-bottom: 0;
}

.form-label {
  flex: 0 0 96rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.form-input {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 28rpx;
}

.save-button {
  margin-top: 24rpx;
  border-radius: 8rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 30rpx;
}

.error-panel {
  margin-top: 24rpx;
  border-radius: 8rpx;
  padding: 24rpx;
  background: #fff1f0;
  color: #cf1322;
  font-size: 26rpx;
}

.product-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.refresh-button {
  width: 132rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1677ff;
  font-size: 26rpx;
}

.empty-panel {
  border-radius: 8rpx;
  padding: 36rpx;
  background: #ffffff;
  color: #6b7280;
  text-align: center;
  font-size: 28rpx;
}

.product-list {
  display: grid;
  gap: 16rpx;
}

.product-item {
  display: flex;
  gap: 18rpx;
  border-radius: 8rpx;
  padding: 24rpx;
  background: #ffffff;
}

.product-main {
  flex: 1;
  min-width: 0;
}

.product-title-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.product-name {
  min-width: 0;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  word-break: break-all;
}

.stock-text {
  flex: 0 0 auto;
  color: #1677ff;
  font-size: 30rpx;
  font-weight: 700;
}

.price-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.price-label {
  display: block;
  color: #6b7280;
  font-size: 22rpx;
}

.price-value {
  display: block;
  margin-top: 6rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
  word-break: break-all;
}

.profit-text {
  color: #16a34a;
}

.stock-row {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.product-remark {
  display: block;
  margin-top: 10rpx;
  color: #4b5563;
  font-size: 26rpx;
  word-break: break-all;
}

.delete-button {
  width: 112rpx;
  flex: 0 0 112rpx;
  margin: 0;
  align-self: center;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
}
